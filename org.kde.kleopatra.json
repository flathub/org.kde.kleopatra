                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/mimetreeparser-26.04.0.tar.xz",
                    "sha256": "91059c4c79463d2ae9a41f9ce4c0bedb251f63d8d2e6aa6e34496990eb64e4e3",
                    "x-checker-data": {
                        "type": "anitya",
