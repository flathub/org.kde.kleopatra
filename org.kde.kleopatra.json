                    "url": "https://download.kde.org/stable/release-service/25.12.2/src/kleopatra-25.12.2.tar.xz",
                    "sha256": "b9bed89fe400b47cc250900e30b2c4801a60cb5f19d19be82de3a0f09cf65f93",
                    "x-checker-data": {
                        "type": "anitya",
