                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/kmbox-26.04.0.tar.xz",
                    "sha256": "314e7af47da88d371b01c7c1e3157ae13ffc6200b6f822665bbe0c7a3d2558ee",
