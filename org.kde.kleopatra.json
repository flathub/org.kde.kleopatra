                    "sha256": "c5816b9c46dc46e3f11a805c7a9508db2c33ad0fbf98d7e8fe681eb9bd8f84f6",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/release-service/$version/src/libkleo-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "kmime",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.0/src/kmime-26.04.0.tar.xz",
                    "sha256": "ce8d5c95f8beaa1dc11201d1ee903689955455247c76cdaf8ef17400bffd4ad1",
                    "x-checker-data": {
                        "type": "anitya",
