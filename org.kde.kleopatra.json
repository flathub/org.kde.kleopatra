        },
        {
            "name": "kleopatra",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/25.12.3/src/kleopatra-25.12.3.tar.xz",
                    "sha256": "2d5f02713e07594a8e8c693331776d957e91413ce48ac85c240be91fd670d9ab",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 8763,
                        "stable-only": true,
