        },
        {
            "name": "kmime",
            "buildsystem": "cmake-ninja",
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/release-service/26.04.1/src/kmime-26.04.1.tar.xz",
                    "sha256": "79616a7bc28710f8f2fc4e7eee53342e83c58969eef09ba70e63ee2017472e6a",
                    "x-checker-data": {
